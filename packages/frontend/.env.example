# ---------------------------------------------------------------------------
# LC Clause Negotiation — frontend environment variables
# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
#
# Note: only variables prefixed with VITE_ are exposed to the browser.
# The frontend currently relies on Vite's dev-server proxy to the backend
# (see vite.config.ts), so no runtime env vars are strictly required in
# development. Set VITE_API_BASE_URL if you deploy the frontend separately
# from the backend.
# ---------------------------------------------------------------------------

# Absolute URL of the backend API. Leave blank to use the Vite proxy.
VITE_API_BASE_URL=
