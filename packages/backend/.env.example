# ---------------------------------------------------------------------------
# LC Clause Negotiation — backend environment variables
# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
# ---------------------------------------------------------------------------

# --- Runtime ---------------------------------------------------------------
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
MAX_FILE_SIZE_MB=10

# --- Database --------------------------------------------------------------
# PostgreSQL 15 with the pgvector extension enabled.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lc_copilot?schema=public

# --- Auth ------------------------------------------------------------------
# Generate a strong random value, e.g.  `openssl rand -base64 48`
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=8h

# --- Anthropic (required for clause parsing, risk analysis, alt wordings,
# report generation, and — if OPENAI_API_KEY is not set — embeddings) -------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Embeddings (optional) -------------------------------------------------
# If set, OpenAI `text-embedding-3-small` is preferred for RAG embeddings;
# otherwise the service falls back to Claude extraction → deterministic mock.
OPENAI_API_KEY=
VECTOR_DIMENSIONS=1536
